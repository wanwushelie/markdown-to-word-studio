# Public base URL of your app (must be reachable by browser and Collabora)
PUBLIC_APP_URL=https://docs.example.com

# Strong random secret for WOPI token signing
WOPI_SECRET=replace-with-a-long-random-secret

# Feature flags (optional, can be auto-detected if unset)
ENABLE_LOCAL_PDF=false
ENABLE_COLLABORA=false
ENABLE_LOCAL_PREVIEW=false

# Collabora endpoint used by app container
# If using docker-compose.server.yml with collabora service, keep this value.
CODE_URL=http://collabora:9980

# Optional Collabora admin credentials
CODE_ADMIN_USER=admin
CODE_ADMIN_PASS=replace-with-strong-password

# Collabora allowed host/domain (escape dots if needed by your environment)
COLLABORA_DOMAIN=docs\\.example\\.com
