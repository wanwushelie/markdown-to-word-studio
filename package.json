{
  "name": "markdowntoword",
  "version": "1.0.0",
  "description": "Markdown to Word (.docx) converter with customizable styling",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "md2word": "dist/cli.js"
  },
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts src/server.ts --format esm --dts",
    "dev": "tsup src/index.ts src/cli.ts src/server.ts --format esm --dts --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "cli": "node dist/cli.js",
    "server": "node dist/server.js",
    "compose:up": "docker-compose up --build",
    "compose:down": "docker-compose down -v"
  },
  "keywords": [
    "markdown",
    "docx",
    "word",
    "converter"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "cors": "^2.8.6",
    "docx": "^9.6.1",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "fast-xml-parser": "^5.7.2",
    "libreoffice": "^0.4.5",
    "libreoffice-convert": "^1.8.1",
    "markdown-it": "^14.1.1",
    "sharp": "^0.34.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.6.0",
    "tsup": "^8.5.1",
    "typescript": "~5.8.0",
    "vitest": "^4.1.5"
  }
}
